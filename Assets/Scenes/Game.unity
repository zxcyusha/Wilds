--- !u!114 &395857810
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 395857808}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0435\u0440\u0432\u043E\u0435, \u0447\u0442\u043E \u0442\u0435\u0431\u0435
    \u043D\u0443\u0436\u043D\u043E - \u0432\u044B\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C \u0431\u0443\u0440-\u043C\u0430\u0448\u0438\u043D\u044B.
    \u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0432\u043D\u0430 A/t, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u0432 \u043B\u0438\u0441\u0442\u0435 \u0441 \u0437\u0430\u0434\u0430\u043D\u0438\u0435\u043C
    \u043D\u0430 \u0434\u0435\u043D\u044C \u0432\u043E\u0437\u044C\u043C\u0438 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0434\u043E\u0431\u044B\u0432\u0430\u0435\u043C\u043E\u0439 \u0440\u0443\u0434\u044B
    \u0438 \u0440\u0430\u0437\u0434\u0435\u043B\u0438 \u044D\u0442\u043E \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043D\u0430 \u0432\u0440\u0435\u043C\u044F \u0434\u043E\u0431\u044B\u0432\u0430\u043D\u0438\u044F.
    \u042D\u0442\u043E \u0438 \u0431\u0443\u0434\u0435\u0442 \u043D\u0443\u0436\u043D\u0430\u044F
    \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C. \u0422\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E
    \u0431\u0443\u0434\u0435\u0442 \u043F\u043E\u0434\u043E\u0439\u0442\u0438 \u043A
    \u0431\u0443\u0440-\u043C\u0430\u0448\u0438\u043D\u0435 \u0438 \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C
    \u0435\u0451 \u0441\u0442\u0440\u0435\u043B\u043E\u0447\u043A\u043E\u0439.\n\u0414\u0430\u043B\u044C\u0448\u0435
    \u043D\u0443\u0436\u043D\u043E \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043C\u0430\u0448\u0438\u043D\u044B,
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u0434\u0430\u043D\u044B
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 \u0437\u0430\u0434\u0430\u0447 \u043D\u0430
    \u0434\u0435\u043D\u044C. \u0412\u044B\u0431\u0435\u0440\u0438 \u043D\u0443\u0436\u043D\u044B\u0435
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B, \u0434\u0432\u0438\u0433\u0430\u044F
    \u043C\u044B\u0448\u043A\u043E\u0439 (\u0434\u043E\u043F\u0443\u0441\u043A\u0430\u0435\u0442\u0441\u044F
    \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C \u0434\u043E
    \u0434\u0435\u0441\u044F\u0442\u0438)."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 938482896cf445546b783f1550f1f86f, type: 2}
