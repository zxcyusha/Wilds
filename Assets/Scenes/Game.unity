  m_text: "\u041A\u0430\u0436\u0434\u044B\u0439 \u0438\u0433\u0440\u043E\u0432\u043E\u0439
    \u0434\u0435\u043D\u044C \u0437\u0434\u0435\u0441\u044C \u0431\u0443\u0434\u0443\u0442
    \u0432\u0438\u0441\u0435\u0442\u044C \u0442\u0432\u043E\u0438 \u0437\u0430\u0434\u0430\u0447\u0438.
    \u0412\u044B\u043F\u043E\u043B\u043D\u044F\u0439 \u0438\u0445 \u0432 \u0442\u043E\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D\u0438 \u0434\u0430\u043D\u044B.
    \u041F\u043E\u0441\u043B\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F
    \u043F\u043E\u0434\u043E\u0439\u0434\u0438 \u043A \u043B\u0438\u0444\u0442\u0443
    \u0438 \u0437\u0430\u043A\u043E\u043D\u0447\u0438 \u0434\u0435\u043D\u044C."
