  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041A\u0430\u043D\u0430\u0440\u0435\u0439\u043A\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u0432 \u0448\u0430\u0445\u0442\u0430\u0445 \u0434\u043B\u044F \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0438\u044F
    \u043E\u043F\u0430\u0441\u043D\u044B\u0445 \u0433\u0430\u0437\u043E\u0432, \u0442\u0430\u043A
    \u043A\u0430\u043A \u043E\u043D\u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B
    \u043A \u0437\u0430\u043F\u0430\u0445\u0430\u043C. \u041E\u043D\u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u044E\u0442
    \u0431\u044B\u0441\u0442\u0440\u043E \u0438 \u0431\u0435\u0437\u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C \u0437\u0430\u0433\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0443\u0447\u0430\u0441\u0442\u043A\u0438 \u0432 \u0430\u0432\u0430\u0440\u0438\u0439\u043D\u044B\u0445
    \u0432\u044B\u0440\u0430\u0431\u043E\u0442\u043A\u0430\u0445. \u0412 \u044D\u0442\u043E\u0439
    \u043A\u043E\u043C\u043D\u0430\u0442\u0435 \u0442\u0432\u043E\u044F \u0437\u0430\u0434\u0430\u0447\u0430
    - \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434\u0430,
    \u043F\u043E\u0434\u0430\u0432\u0430\u0435\u043C\u044B\u0439 \u043A\u0430\u043D\u0430\u0440\u0435\u0439\u043A\u0435.
    \u041F\u043E\u0434\u043A\u0440\u0443\u0442\u0438 3 \u043A\u0440\u0430\u043D\u0430
    \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0435 \u0434\u043E \u0437\u0435\u043B\u0451\u043D\u043E\u0439
    \u043E\u0442\u043C\u0435\u0442\u043A\u0438. \u0415\u0441\u043B\u0438 \u0442\u044B
    \u043D\u0435 \u0441\u0434\u0435\u043B\u0430\u0435\u0448\u044C \u044D\u0442\u043E\u0433\u043E,
    \u0442\u043E \u043A\u0430\u043D\u0430\u0440\u0435\u0439\u043A\u0430 \u0443\u043C\u0440\u0451\u0442,
    \u0430 \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0434\u0435\u043D\u044C
    \u043D\u0430 \u0435\u0451 \u043C\u0435\u0441\u0442\u043E \u043F\u043E\u0441\u0430\u0434\u044F\u0442
    \u043D\u043E\u0432\u0443\u044E, \u0442\u0430\u043A \u043A\u0430\u043A \u0431\u0435\u0437
    \u043A\u0430\u043D\u0430\u0440\u0435\u0439\u043A\u0438 \u0432 \u0448\u0430\u0445\u0442\u0435
    \u043E\u0431\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043D\u0435\u043B\u044C\u0437\u044F,
    \u043E\u0434\u043D\u0430\u043A\u043E \u044D\u0442\u043E \u0443\u0445\u0443\u0434\u0448\u0438\u0442
    \u0442\u0432\u043E\u0451 \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435."
  m_isRightToLeft: 0
